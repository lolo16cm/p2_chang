#!/usr/bin/env python3

import rospy
import cv2
import numpy as np
from sensor_msgs.msg import Image
from geometry_msgs.msg import Twist
from cv_bridge import CvBridge

class BallFollower:
    def __init__(self):
        self.bridge = CvBridge()

        self.cmd_pub   = rospy.Publisher('/cmd_vel_mux/input/teleop', Twist, queue_size=1)
        self.image_pub = rospy.Publisher('/image_converter/output_video', Image, queue_size=1)

        # Depth only — no RGB needed
        rospy.Subscriber('/camera/depth/image_raw', Image, self.depth_callback)

        self.front_dist  = None
        self.ball_col    = None
        self.depth_image = None

        self.target_dist = 1.0
        self.tolerance   = 0.1

        rospy.loginfo("Ball Follower (Depth Only) Started!")

    def depth_callback(self, msg):
        try:
            # Try 16UC1 (millimeters) first
            depth_raw = self.bridge.imgmsg_to_cv2(msg, '16UC1')
            self.depth_image = depth_raw.astype(np.float32) / 1000.0
        except:
            try:
                self.depth_image = self.bridge.imgmsg_to_cv2(msg, '32FC1')
            except Exception as e:
                rospy.logerr("Depth error: %s", str(e))
                return

        h, w = self.depth_image.shape

        # Look at center band of image (middle 1/3 rows)
        row_start = h // 3
        row_end   = 2 * h // 3
        center_band = self.depth_image[row_start:row_end, :]

        # Mask out invalid/zero readings
        valid_mask = (center_band > 0.1) & (center_band < 5.0) & np.isfinite(center_band)

        if np.any(valid_mask):
            # Find column of closest valid point
            center_band_masked = np.where(valid_mask, center_band, np.inf)
            min_idx = np.unravel_index(
                np.argmin(center_band_masked), center_band_masked.shape)
            self.ball_col   = min_idx[1]           # column in image
            self.front_dist = float(center_band_masked[min_idx])
        else:
            self.ball_col   = None
            self.front_dist = None

        # Visualize depth as grayscale
        vis = np.clip(self.depth_image, 0, 5.0)
        vis = (vis / 5.0 * 255).astype(np.uint8)
        vis_color = cv2.cvtColor(vis, cv2.COLOR_GRAY2BGR)

        # Draw center band
        cv2.rectangle(vis_color, (0, row_start), (w, row_end), (0, 255, 0), 2)

        # Draw closest point
        if self.ball_col is not None:
            cv2.circle(vis_color,
                       (self.ball_col, (row_start + row_end) // 2),
                       10, (0, 0, 255), -1)

        dist_text = "{:.2f}m".format(self.front_dist) if self.front_dist else "N/A"
        cv2.putText(vis_color, "dist: " + dist_text,
                    (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 0), 2)
        cv2.putText(vis_color, "target: 1.0m",
                    (10, 60), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 255), 2)

        self.image_pub.publish(
            self.bridge.cv2_to_imgmsg(vis_color, 'bgr8'))

    def follow(self):
        rate      = rospy.Rate(10)
        img_width = 640

        while not rospy.is_shutdown():
            twist = Twist()

            if self.ball_col is not None and self.front_dist is not None:
                # Turn toward closest object
                error = self.ball_col - img_width // 2
                twist.angular.z = -float(error) / 300.0

                dist_error = self.front_dist - self.target_dist

                if dist_error > self.tolerance:
                    twist.linear.x = min(0.2, dist_error * 0.4)
                elif dist_error < -self.tolerance:
                    twist.linear.x = max(-0.2, dist_error * 0.4)
                else:
                    twist.linear.x = 0.0

                rospy.loginfo("dist: %.2fm | target: 1.0m | error: %.2fm",
                              self.front_dist, dist_error)
            else:
                twist.linear.x  = 0.0
                twist.angular.z = 0.0
                rospy.loginfo("No object detected, stopping...")

            self.cmd_pub.publish(twist)
            rate.sleep()

if __name__ == '__main__':
    rospy.init_node('ball_follower')
    follower = BallFollower()
    follower.follow()